---
const { title, price, mainImage, description } = Astro.props;
import { Image } from "astro:assets";
---

<div class="group">
  <Image src={mainImage} alt="Item Image" class="w-64 h-56 rounded-xl object-cover shadow-xl transition lg:w-96 group-hover:animate-background group-hover:bg-gradient-to-r group-hover:from-primary group-hover:via-error group-hover:to-secondary group-hover:bg-[length:400%_400%] group-hover:shadow-sm group-hover:[animation-duration:_2s] group-hover:p-1"/>

  <div class="pt-4 w-64 lg:w-96">
    <h1 class="text-lg font-bold text-error">{price}</h1>
    <h3 class="text-lg font-medium text-inherit">
      {title}
    </h3>
    <p class="mt-2 line-clamp-3 text-sm/relaxed text-inherit">
      {description}
    </p>
  </div>
</div>
